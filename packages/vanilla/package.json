{
  "name": "@kenikool/vanilla",
  "version": "0.1.0",
  "description": "Vanilla JavaScript Web Components for Kenikool UI",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "dev": "vite",
    "preview": "vite preview",
    "test": "vitest run",
    "test:property": "vitest run --grep 'Property'",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src"
  },
  "keywords": [
    "kenikool",
    "ui",
    "web-components",
    "vanilla",
    "javascript"
  ],
  "author": "Kenikool",
  "license": "MIT",
  "dependencies": {
    "@kenikool/core": "*"
  },
  "peerDependencies": {
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "fast-check": "^3.13.0",
    "jsdom": "^23.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
